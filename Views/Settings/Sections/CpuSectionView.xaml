<UserControl x:Class="Kil0bitSystemMonitor.Views.Settings.Sections.CpuSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <StackPanel>
        <TextBlock Text="CPU" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>
        <StackPanel>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE734;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Show CPU Usage" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.ShowCpuPercent, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE7F8;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Show CPU Clock" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.ShowCpuClock, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE790;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Accent Color" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><Button Grid.Column="2" VerticalAlignment="Center" Click="ColorButton_Click" Tag="CpuAccent" Height="36" Content="Select Accent"/></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE8D2;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Label Color" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><Button Grid.Column="2" VerticalAlignment="Center" Click="ColorButton_Click" Tag="CpuLabel" Height="36" Content="Select Label"/></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Graph Color" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><Button Grid.Column="2" VerticalAlignment="Center" Click="ColorButton_Click" Tag="CpuGraph" Height="36" Content="Select Graph"/></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9CE;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Display Mode" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" SelectedValue="{Binding Config.CpuDisplayMode, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Text"/><ComboBoxItem Content="TextGraph"/></ComboBox></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Graph Style" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" SelectedValue="{Binding Config.CpuGraphStyle, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Line"/><ComboBoxItem Content="Bar"/><ComboBoxItem Content="Pie"/></ComboBox></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9CE;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Clock Display Mode" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" SelectedValue="{Binding Config.CpuClockDisplayMode, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Text"/><ComboBoxItem Content="TextGraph"/></ComboBox></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Clock Graph Style" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" SelectedValue="{Binding Config.CpuClockGraphStyle, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Line"/><ComboBoxItem Content="Bar"/><ComboBoxItem Content="Pie"/></ComboBox></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9CE;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Threshold Override" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.CpuThresholdOverrideEnabled, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9CE;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Warn Threshold" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><Grid Grid.Column="2" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="56"/></Grid.ColumnDefinitions><Slider Grid.Column="0" Minimum="50" Maximum="98" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Config.CpuWarnThreshold, Mode=TwoWay}" Margin="0,0,10,0"/><TextBox Grid.Column="1" Text="{Binding Config.CpuWarnThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/></Grid></Grid></Border>
            <Border Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xEA39;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="CPU Critical Threshold" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><Grid Grid.Column="2" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="56"/></Grid.ColumnDefinitions><Slider Grid.Column="0" Minimum="55" Maximum="99" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Config.CpuCriticalThreshold, Mode=TwoWay}" Margin="0,0,10,0"/><TextBox Grid.Column="1" Text="{Binding Config.CpuCriticalThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/></Grid></Grid></Border>
        </StackPanel>
    </StackPanel>
</UserControl>
