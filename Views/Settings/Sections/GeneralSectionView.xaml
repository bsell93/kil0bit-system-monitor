<UserControl x:Class="Kil0bitSystemMonitor.Views.Settings.Sections.GeneralSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <StackPanel>
        <TextBlock Text="General" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE7B3;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"><TextBlock Text="Show Overlay" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Left" IsOn="{Binding Config.ShowOverlay, Mode=TwoWay}" VerticalAlignment="Center"/></Grid></Border>
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE718;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"><TextBlock Text="Lock Position" Style="{StaticResource SettingsCardTitleTextStyle}"/><TextBlock Text="Prevent accidental dragging." Style="{StaticResource SettingsCardDescriptionTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Left" IsOn="{Binding Config.LockPosition, Mode=TwoWay}" VerticalAlignment="Center"/></Grid></Border>
            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE72A;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"><TextBlock Text="Run at Startup" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Left" IsOn="{Binding Config.LaunchOnStartup, Mode=TwoWay}" VerticalAlignment="Center"/></Grid></Border>
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE740;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"><TextBlock Text="Hide in Fullscreen" Style="{StaticResource SettingsCardTitleTextStyle}"/><TextBlock Text="Hide during games/movies." Style="{StaticResource SettingsCardDescriptionTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Left" IsOn="{Binding Config.HideOnFullscreen, Mode=TwoWay}" VerticalAlignment="Center"/></Grid></Border>
            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE90E;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"><TextBlock Text="Snap to Taskbar" Style="{StaticResource SettingsCardTitleTextStyle}"/><TextBlock Text="Dock to the taskbar area." Style="{StaticResource SettingsCardDescriptionTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Left" IsOn="{Binding Config.StickToTaskbar, Mode=TwoWay}" VerticalAlignment="Center"/></Grid></Border>
            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource SettingsCardBorderStyle}"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE819;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"><TextBlock Text="Keep on Top" Style="{StaticResource SettingsCardTitleTextStyle}"/></StackPanel><ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Left" IsOn="{Binding Config.AlwaysOnTop, Mode=TwoWay}" VerticalAlignment="Center"/></Grid></Border>
            <Border Grid.Row="3" Grid.ColumnSpan="3" Style="{StaticResource SettingsCardBorderStyle}" Margin="0,4,0,10"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE916;" Style="{StaticResource SettingsCardIconStyle}"/><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"><TextBlock Text="Refresh Rate" Style="{StaticResource SettingsCardTitleTextStyle}"/><TextBlock Text="Set how often the monitor updates its metrics." Style="{StaticResource SettingsCardDescriptionTextStyle}"/></StackPanel><ComboBox Grid.Column="2" SelectedValue="{Binding Config.UpdateInterval, Mode=TwoWay}" SelectedValuePath="Tag" HorizontalAlignment="Stretch" VerticalAlignment="Center"><ComboBoxItem Content="500ms (High Performance)"><ComboBoxItem.Tag><sys:Int32>500</sys:Int32></ComboBoxItem.Tag></ComboBoxItem><ComboBoxItem Content="1000ms (Default)"><ComboBoxItem.Tag><sys:Int32>1000</sys:Int32></ComboBoxItem.Tag></ComboBoxItem><ComboBoxItem Content="2000ms (Relaxed)"><ComboBoxItem.Tag><sys:Int32>2000</sys:Int32></ComboBoxItem.Tag></ComboBoxItem><ComboBoxItem Content="5000ms (Power Saver)"><ComboBoxItem.Tag><sys:Int32>5000</sys:Int32></ComboBoxItem.Tag></ComboBoxItem></ComboBox></Grid></Border>
        </Grid>
    </StackPanel>
</UserControl>
