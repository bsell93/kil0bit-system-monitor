<UserControl x:Class="Kil0bitSystemMonitor.Views.Settings.Sections.AboutSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <StackPanel>
        <TextBlock Text="About" Foreground="#00CCFF" FontSize="20" Margin="0,0,0,16"/>
        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Kil0bit System Monitor" FontWeight="Bold" FontSize="18"/>
            <TextBlock Text="{Binding AppVersion}" Opacity="0.7" FontSize="13"/>
            <TextBlock Text="A lightweight, high-performance system monitoring overlay designed for power users. Built with WPF and GDI+ rendering." TextWrapping="Wrap" MaxWidth="600" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>
        <Separator Background="#1AFFFFFF" Margin="0,10"/>
        <TextBlock Text="Connect with the Developer" FontWeight="SemiBold" FontSize="16" Margin="0,20,0,4"/>
        <Grid HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ui:HyperlinkButton Grid.Row="0" Grid.Column="0" Content="YouTube (@kilObit)" NavigateUri="https://www.youtube.com/@kilObit" FontSize="14" Margin="0,0,16,10"/>
            <ui:HyperlinkButton Grid.Row="0" Grid.Column="1" Content="GitHub (kil0bit-kb)" NavigateUri="https://github.com/kil0bit-kb" FontSize="14" Margin="0,0,0,10"/>
            <ui:HyperlinkButton Grid.Row="1" Grid.Column="0" Content="Blog (kil0bit.blogspot.com)" NavigateUri="https://kil0bit.blogspot.com/" FontSize="14" Margin="0,0,16,10"/>
            <ui:HyperlinkButton Grid.Row="1" Grid.Column="1" Content="X (@kil0bit)" NavigateUri="https://x.com/kil0bit" FontSize="14" Margin="0,0,0,10"/>
            <ui:HyperlinkButton Grid.Row="2" Grid.Column="0" Content="Support Me (Patreon)" NavigateUri="https://www.patreon.com/cw/KB_kilObit" FontSize="14" Margin="0,0,16,10"/>
        </Grid>
        <StackPanel Margin="0,30,0,0" Opacity="0.6">
            <TextBlock Text="Built with ❤️ by KB - kil0bit" HorizontalAlignment="Center" FontSize="12"/>
            <TextBlock Text="© 2026 Kil0bit System Monitor" HorizontalAlignment="Center" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>
    </StackPanel>
</UserControl>
