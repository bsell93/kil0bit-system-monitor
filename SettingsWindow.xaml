                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Disk Space Graph Style" FontWeight="SemiBold" FontSize="15"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.DiskSpaceGraphStyle, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Line"/><ComboBoxItem Content="Bar"/><ComboBoxItem Content="Pie"/></ComboBox><Button Grid.Column="2" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" Click="ResetMetricOverride_Click" Tag="DiskSpaceGraphStyle" Visibility="{Binding Config.DiskSpaceGraphStyleOverride, Converter={StaticResource NonNullToVisibilityConverter}}" ToolTip="Reset to Defaults"><ui:FontIcon Glyph="&#xE894;"/></Button></Grid></Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9CE;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Disk Activity Display Mode" FontWeight="SemiBold" FontSize="15"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.DiskActivityDisplayMode, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Text"/><ComboBoxItem Content="Graph"/><ComboBoxItem Content="TextGraph"/></ComboBox><Button Grid.Column="2" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" Click="ResetMetricOverride_Click" Tag="DiskActivityDisplayMode" Visibility="{Binding Config.DiskActivityDisplayModeOverride, Converter={StaticResource NonNullToVisibilityConverter}}" ToolTip="Reset to Defaults"><ui:FontIcon Glyph="&#xE894;"/></Button></Grid></Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Disk Activity Graph Style" FontWeight="SemiBold" FontSize="15"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.DiskActivityGraphStyle, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Line"/><ComboBoxItem Content="Bar"/><ComboBoxItem Content="Pie"/></ComboBox><Button Grid.Column="2" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" Click="ResetMetricOverride_Click" Tag="DiskActivityGraphStyle" Visibility="{Binding Config.DiskActivityGraphStyleOverride, Converter={StaticResource NonNullToVisibilityConverter}}" ToolTip="Reset to Defaults"><ui:FontIcon Glyph="&#xE894;"/></Button></Grid></Border>
                                    </StackPanel>
                                            </Grid>
<TextBlock Text="Thresholds" FontSize="15" FontWeight="SemiBold" Margin="0,12,0,4" Opacity="0.9"/>
                            <Grid>
                                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9CE;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Disk Warn Threshold" FontWeight="SemiBold" FontSize="15"/></StackPanel><Grid Grid.Column="2" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="56"/></Grid.ColumnDefinitions><Slider Grid.Column="0" Minimum="50" Maximum="98" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Config.DiskWarnThreshold, Mode=TwoWay}" Margin="0,0,10,0"/><TextBox Grid.Column="1" Text="{Binding Config.DiskWarnThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/></Grid></Grid></Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xEA39;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Disk Critical Threshold" FontWeight="SemiBold" FontSize="15"/></StackPanel><Grid Grid.Column="2" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="56"/></Grid.ColumnDefinitions><Slider Grid.Column="0" Minimum="55" Maximum="99" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Config.DiskCriticalThreshold, Mode=TwoWay}" Margin="0,0,10,0"/><TextBox Grid.Column="1" Text="{Binding Config.DiskCriticalThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/></Grid></Grid></Border>
                            </StackPanel>
