<Window
    x:Class="Kil0bitSystemMonitor.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    xmlns:local="clr-namespace:Kil0bitSystemMonitor"
    xmlns:settingsSections="clr-namespace:Kil0bitSystemMonitor.Views.Settings.Sections"
    xmlns:helpers="clr-namespace:Kil0bitSystemMonitor.Helpers"
    mc:Ignorable="d"
    Title="Kil0bit System Monitor Settings"
    Height="720" Width="1764" MinWidth="1260"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    ui:WindowHelper.UseModernWindowStyle="True"
    ui:ThemeManager.RequestedTheme="Dark">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Kil0bitSystemMonitor;component/Views/Settings/Templates/SettingsCardTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <helpers:DoubleTextConverter x:Key="DoubleTextConverter" />
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <helpers:NonNullToVisibilityConverter x:Key="NonNullToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="SettingsRoot" Loaded="SettingsRoot_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:NavigationView x:Name="SettingsNav" 
                        Grid.Row="0"
                        PaneDisplayMode="Left"
                        OpenPaneLength="200"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        SelectionChanged="SettingsNav_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Home" Tag="Home" IsSelected="True">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="General" Tag="General">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Setting" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Defaults" Tag="GlobalStyle">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Edit" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Network" Tag="Network">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="World" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="CPU" Tag="Cpu">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="FourBars" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="RAM" Tag="Ram">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="AllApps" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="GPU" Tag="Gpu">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Video" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Disk" Tag="Disk">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Folder" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="About" Tag="About">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Help" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Stretch" Margin="24">
                    <!-- Home Section -->
                    <StackPanel x:Name="HomeSection" Visibility="Visible">
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock Text="Welcome" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,0,0,4">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.3" ShadowDepth="2"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="Kil0bit System Monitor is active and tracking your hardware performance with near-zero overhead." 
                                       FontSize="17" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" />
                        </StackPanel>

                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- General Card -->
                            <Button Grid.Row="0" Grid.Column="0" x:Name="HomeGeneralBtn" Click="HomeCard_Click" Tag="General" MinWidth="280" Margin="0,0,16,16" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Top">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Setting" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="General" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Startup behavior, updates, and core system settings." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- Defaults Card -->
                            <Button Grid.Row="0" Grid.Column="1" x:Name="HomeMonitoringBtn" Click="HomeCard_Click" Tag="GlobalStyle" MinWidth="280" Margin="0,0,0,16" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Top">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Edit" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Defaults" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Default style for all metrics, with per-metric overrides." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- CPU Card -->
                            <Button Grid.Row="1" Grid.Column="0" x:Name="HomeAppearanceBtn" Click="HomeCard_Click" Tag="Cpu" MinWidth="280" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Top">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="FourBars" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="CPU" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Manage CPU metrics, thresholds, and metric visuals." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- About Card -->
                            <Button Grid.Row="1" Grid.Column="1" x:Name="HomeAboutBtn" Click="HomeCard_Click" Tag="About" MinWidth="280" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Top">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                        BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        Padding="16" CornerRadius="12">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Help" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="About" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                                            <TextBlock Text="Version info, documentation, and support links." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </Grid>

                        <!-- InfoBar Replacement -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="4" Padding="16" Margin="0,20,0,0" BorderBrush="{DynamicResource SystemAccentColorBrush}" BorderThickness="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Accept" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Performance Note" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="Your system is being monitored using low-level Win32 APIs for maximum precision." Opacity="0.8" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- General Section -->
                    <settingsSections:GeneralSectionView x:Name="GeneralSection" Visibility="Collapsed"/>
                        
                    <!-- Defaults Section -->
                    <StackPanel x:Name="GlobalStyleSection" Visibility="Collapsed">
                        <TextBlock Text="Defaults" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>
                        <StackPanel>
                            <TextBlock Text="Theme &amp; Layout" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4" Opacity="0.9"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE790;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Global Display Mode" FontWeight="SemiBold" FontSize="15"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.GlobalDisplayMode, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Text"/><ComboBoxItem Content="TextGraph"/></ComboBox></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Global Graph Style" FontWeight="SemiBold" FontSize="15"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.GlobalGraphStyle, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Line"/><ComboBoxItem Content="Bar"/><ComboBoxItem Content="Pie"/></ComboBox></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE8D2;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Font Family" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Typography for overlay labels and values." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.FontFamily, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Segoe UI"/><ComboBoxItem Content="Segoe UI Variable Display"/><ComboBoxItem Content="Inter"/><ComboBoxItem Content="Roboto"/><ComboBoxItem Content="Consolas"/></ComboBox></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE7B8;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Overlay Mode" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Choose text or compact overlay style." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.DisplayStyle, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Text"/><ComboBoxItem Content="Compact"/></ComboBox></Grid>
                            </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE8D0;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Scale" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Resize overlay without changing data density." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><Slider Grid.Column="2" Minimum="0.5" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding Config.ScaleFactor, Mode=TwoWay}"/></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE8DD;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Bold Text" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Increase text weight for readability." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.IsTextBold, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE8FD;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Enable Capsules" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Draw metric cards around each column." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.ShowPods, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE91F;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Background Plate" FontWeight="SemiBold" FontSize="15"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.ShowBackground, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid>
                            </Border>
                                    </StackPanel>
                            </Grid><TextBlock Text="Graphing" FontSize="15" FontWeight="SemiBold" Margin="0,12,0,4" Opacity="0.9"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Inline Graphs" FontWeight="SemiBold" FontSize="15"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.EnableInlineGraphs, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE81C;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="History Preset" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Configure graph memory window length." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.GraphHistoryPreset, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Short"/><ComboBoxItem Content="Medium"/><ComboBoxItem Content="Long"/></ComboBox></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9D2;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Inline Graph Style" FontWeight="SemiBold" FontSize="15"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.InlineGraphStyle, Mode=TwoWay}" SelectedValuePath="Content"><ComboBoxItem Content="Line"/><ComboBoxItem Content="Bar"/><ComboBoxItem Content="Pie"/></ComboBox></Grid>
                            </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE8A1;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Graph Point Count" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="How many recent samples are plotted across each inline graph; higher values show finer changes over the same width." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><Slider Grid.Column="2" Minimum="16" Maximum="80" TickFrequency="4" IsSnapToTickEnabled="True" Value="{Binding Config.GraphPointCount, Mode=TwoWay}"/></Grid>
                            </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE8A1;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Graph Opacity" FontWeight="SemiBold" FontSize="15"/></StackPanel><Slider Grid.Column="2" Minimum="8" Maximum="96" TickFrequency="4" IsSnapToTickEnabled="True" Value="{Binding Config.GraphOpacity, Mode=TwoWay}"/></Grid>
                            </Border>
                                    </StackPanel>
                            </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE9CE;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Threshold Coloring" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Color metric values by warn/critical levels." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center" IsOn="{Binding Config.EnableThresholdColors, Mode=TwoWay}" HorizontalAlignment="Left"/></Grid>
                            </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*" MaxWidth="380"/><ColumnDefinition Width="248"/></Grid.ColumnDefinitions><ui:FontIcon Glyph="&#xE713;" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center"><TextBlock Text="Threshold Profile" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="Choose balanced or stricter alert behavior." Opacity="0.6" FontSize="12.5" TextWrapping="Wrap"/></StackPanel><ComboBox Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.ThresholdProfile, Mode=TwoWay}" SelectionChanged="ThresholdProfile_SelectionChanged" SelectedValuePath="Content"><ComboBoxItem Content="Balanced"/><ComboBoxItem Content="Conservative"/><ComboBoxItem Content="Aggressive"/></ComboBox></Grid>
                            </Border>
                                    </StackPanel>
                            </Grid>
                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="20,16">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
